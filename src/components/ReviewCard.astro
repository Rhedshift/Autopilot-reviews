---
import type { CollectionEntry } from 'astro:content';

interface Props {
    review: CollectionEntry<'reviews'>;
}

const { review } = Astro.props;
const { title, description, heroImage, rating, category, affiliateLink } = review.data;
---

<div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden hover:shadow-md transition-shadow">
    <a href={`${import.meta.env.BASE_URL}/reviews/${review.id}`} class="block">
        <img src={heroImage} alt={title} class="w-full h-48 object-cover" />
    </a>
    <div class="p-6">
        <div class="flex justify-between items-start mb-2">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800 uppercase">
                {category}
            </span>
            <div class="flex items-center">
                <span class="text-yellow-400">★</span>
                <span class="ml-1 text-sm font-bold text-slate-700">{rating}</span>
            </div>
        </div>
        <h3 class="text-xl font-bold text-slate-900 mb-2 leading-tight">
            <a href={`${import.meta.env.BASE_URL}/reviews/${review.id}`} class="hover:text-indigo-600 transition-colors">
                {title}
            </a>
        </h3>
        <p class="text-slate-600 text-sm mb-4 line-clamp-2">
            {description}
        </p>
        <div class="flex items-center justify-between mt-auto">
            <a href={`${import.meta.env.BASE_URL}/reviews/${review.id}`} class="text-sm font-semibold text-slate-900 hover:text-indigo-600">
                Read Review &rarr;
            </a>
            <a href={affiliateLink} target="_blank" rel="nofollow sponsored" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                Check Price
            </a>
        </div>
    </div>
</div>